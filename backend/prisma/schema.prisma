// ====================================================================
// ShadowPay - Schema Prisma
// Modelado a partir das interfaces do frontend (AuthContext.tsx)
// ====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------------------
// Enums
// --------------------------------------------------------------------

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  BANNED
}

enum WalletStatus {
  ACTIVE
  BLOCKED
}

enum TransactionStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  CHARGEBACK
  EXPIRED
}

enum TransactionMethod {
  PIX
  CARD
  BOLETO
  CRYPTO
}

enum TransactionType {
  IN
  OUT
  FEE
  REFUND
  ADJUSTMENT
}

// --------------------------------------------------------------------
// Seller (lojista do gateway)
// --------------------------------------------------------------------

model Seller {
  id              String   @id @default(uuid())
  companyName     String
  email           String   @unique
  passwordHash    String
  number          String
  cpf_cnpj        String   @unique
  zipCode         String
  companyModality String
  companyActivity String

  twofaEnabled  Boolean @default(false)
  twofaSecret   String?
  isAdministrator Boolean @default(false)

  // Acquirer (PSP) que esse seller usa por padrão
  adquererId String?

  // Taxas (em decimal, salvas como string pra evitar imprecisão de float)
  feePercentPix     Decimal @default(0.99) @db.Decimal(7, 4)
  feeFixedPix       Decimal @default(0)    @db.Decimal(12, 2)
  feePercentCard    Decimal @default(3.99) @db.Decimal(7, 4)
  feeFixedCard      Decimal @default(0.50) @db.Decimal(12, 2)
  feePercentBoleto  Decimal @default(2.99) @db.Decimal(7, 4)
  feeFixedBoleto    Decimal @default(2.50) @db.Decimal(12, 2)
  feePercentCrypto  Decimal @default(1.99) @db.Decimal(7, 4)
  feeFixedCrypto    Decimal @default(0)    @db.Decimal(12, 2)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  suspendedAt DateTime?

  wallet       Wallet[]
  credentials  Credentials[]
  kyc          Kyc?
  transactions Transaction[]
  withdrawals  Withdrawal[]

  @@index([email])
  @@index([cpf_cnpj])
}

// --------------------------------------------------------------------
// Wallet (carteira do seller)
// --------------------------------------------------------------------

model Wallet {
  id               String       @id @default(uuid())
  sellerId         String
  balance          Decimal      @default(0) @db.Decimal(14, 2)
  blockedBalance   Decimal      @default(0) @db.Decimal(14, 2)
  reservedBalance  Decimal      @default(0) @db.Decimal(14, 2)
  status           WalletStatus @default(ACTIVE)
  isBlocked        Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

// --------------------------------------------------------------------
// Credentials (chave pública/privada da API que o lojista usa)
// --------------------------------------------------------------------

model Credentials {
  id         String    @id @default(uuid())
  sellerId   String
  publicKey  String    @unique
  privateKey String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([publicKey])
}

// --------------------------------------------------------------------
// KYC (Know Your Customer)
// --------------------------------------------------------------------

model Kyc {
  id        String    @id @default(uuid())
  sellerId  String    @unique
  status    KycStatus @default(NOT_STARTED)
  message   String    @default("")

  documentFrontUrl String?
  documentBackUrl  String?
  selfieUrl        String?
  proofOfAddressUrl String?

  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------------
// Transaction (vendas processadas via PSP)
// --------------------------------------------------------------------

model Transaction {
  id              String            @id @default(uuid())
  sellerId        String
  externalId      String?           @unique // ID do PSP
  pspName         String?           // "simpay", "asaas", etc.
  method          TransactionMethod
  status          TransactionStatus @default(PENDING)

  // Valores
  grossAmount Decimal @db.Decimal(14, 2)
  netAmount   Decimal @db.Decimal(14, 2)
  feeAmount   Decimal @db.Decimal(14, 2)

  // Cliente final
  customerName     String?
  customerEmail    String?
  customerCpfCnpj  String?

  // Pagamento
  pixCopyPaste String?
  pixQrCodeUrl String?
  cardLastDigits String?
  boletoBarcode String?
  boletoUrl     String?

  paidAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  seller        Seller         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  walletEntries WalletEntry[]
  webhookEvents WebhookEvent[]

  @@index([sellerId])
  @@index([status])
  @@index([externalId])
  @@index([createdAt])
}

// --------------------------------------------------------------------
// WalletEntry (extrato — toda movimentação de saldo)
// --------------------------------------------------------------------

model WalletEntry {
  id            String          @id @default(uuid())
  sellerId      String
  transactionId String?
  type          TransactionType
  amount        Decimal         @db.Decimal(14, 2)
  description   String
  createdAt     DateTime        @default(now())

  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([sellerId])
  @@index([transactionId])
  @@index([createdAt])
}

// --------------------------------------------------------------------
// Withdrawal (saque)
// --------------------------------------------------------------------

model Withdrawal {
  id          String            @id @default(uuid())
  sellerId    String
  amount      Decimal           @db.Decimal(14, 2)
  feeAmount   Decimal           @default(0) @db.Decimal(14, 2)
  pixKey      String?
  pixKeyType  String?           // "cpf", "cnpj", "email", "phone", "random"
  bankAccount String?
  status      TransactionStatus @default(PENDING)
  externalId  String?
  paidAt      DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([status])
}

// --------------------------------------------------------------------
// PushSubscription (push notifications)
// --------------------------------------------------------------------

model PushSubscription {
  id          String   @id @default(uuid())
  sellerId    String
  endpoint    String   @unique
  p256dh      String
  authKey     String
  userAgent   String?
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())

  @@index([sellerId])
}

// --------------------------------------------------------------------
// WebhookEvent (auditoria de webhooks recebidos do PSP)
// --------------------------------------------------------------------

model WebhookEvent {
  id            String   @id @default(uuid())
  pspName       String
  eventType     String
  payload       Json
  signature     String?
  processed     Boolean  @default(false)
  processingError String?
  transactionId String?
  receivedAt    DateTime @default(now())
  processedAt   DateTime?

  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([pspName])
  @@index([processed])
  @@index([transactionId])
}

// --------------------------------------------------------------------
// Acquirer (PSPs cadastrados — útil pra suportar múltiplos PSPs)
// --------------------------------------------------------------------

model Acquirer {
  id        String   @id @default(uuid())
  name      String   @unique // "simpay", "asaas", etc.
  enabled   Boolean  @default(true)
  config    Json     // credenciais e config específica
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
