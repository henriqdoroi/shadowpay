# ====================================================================
# ShadowPay Backend - .env.example
# Copie esse arquivo para .env e preencha com seus valores reais.
# NUNCA commite o .env no Git.
# ====================================================================

# Banco de dados Postgres
DATABASE_URL="postgresql://user:senha@host:5432/shadowpay?schema=public"

# Servidor
PORT=3333
NODE_ENV=development

# JWT - GERE UMA STRING ALEATORIA LONGA (minimo 64 chars)
# Voce pode gerar com: openssl rand -hex 64
JWT_SECRET="troque-isso-por-uma-string-aleatoria-bem-longa-e-segura-em-producao"
JWT_EXPIRES_IN="7d"

# CORS - URLs do frontend autorizadas (separadas por virgula)
CORS_ORIGINS="http://localhost:3000,https://shadowpay-delta.vercel.app"

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# ====================================================================
# Integracao com PSPs (preencher na proxima fase)
# ====================================================================

# Simpay
SIMPAY_API_URL="https://api.simpay.com.br"
SIMPAY_API_KEY=""
SIMPAY_API_SECRET=""
SIMPAY_WEBHOOK_SECRET=""

# VAPID (push notifications) - gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contato@shadowpay.com"
